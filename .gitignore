# ==========================================
# 1. SECRETS & ENVIRONMENT VARIABLES (CRITICAL)
# ==========================================
# NEVER commit these! They hold your PostgreSQL passwords, 
# Django SECRET_KEY, and API keys.
.env
.env.local
.env.*.local
*.pem
local_settings.py

# ==========================================
# 2. DJANGO & PYTHON BACKEND
# ==========================================
# Virtual Environments
venv/
env/
.venv/
env.bak/

# Byte-compiled / optimized Python files
__pycache__/
*.py[cod]
*$py.class

# Django database & media
db.sqlite3          # Ignored even if using Postgres (good fallback practice)
db.sqlite3-journal
media/              # User-uploaded files shouldn't be versioned
static/             # Only ignore if you run collectstatic locally

# ==========================================
# 3. VUE.JS & NODE.JS FRONTEND
# ==========================================
# Dependencies
node_modules/
.pnp/
.pnp.js

# Production builds
/dist/
/dist-ssr/
/build/

# Package manager logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ==========================================
# 4. POSTGRESQL & DOCKER 
# ==========================================
# If you run Postgres locally via Docker, ignore the data volume
/pgdata/
/postgres-data/
*.sql               # Ignore database dumps (unless specifically needed as seed data)

# ==========================================
# 5. OS & IDE FILES
# ==========================================
# Mac
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# IDEs (VS Code, PyCharm, IntelliJ)
.vscode/
.idea/
*.swp
*.swo